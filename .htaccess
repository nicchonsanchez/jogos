Options -Indexes

RewriteEngine On
RewriteBase /jogos/

# Protege o banco de recordes de acesso direto pelo navegador
<FilesMatch "records\.json$">
    Require all denied
</FilesMatch>

# Para jogos sem subpasta: permite acessar /jogos/jogo mesmo sem extensão .html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/.]+)$ $1.html [L]
